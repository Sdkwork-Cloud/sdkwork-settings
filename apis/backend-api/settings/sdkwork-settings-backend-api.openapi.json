              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Page size for offset pagination. Default 20, maximum 200.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 200,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "System settings list retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemSettingListResponse"
                },
                "example": {
                  "code": 0,
                  "data": {
                    "items": [
                      {
                        "id": 12884901888,
                        "namespace": "platform",
                        "settingKey": "maintenance-mode",
                        "settingValue": { "enabled": false },
                        "valueType": "object",
                        "scope": "global",
                        "scopeValue": null,
                        "createdAt": "2026-07-01T02:30:00.000Z",
                        "updatedAt": "2026-07-01T02:30:00.000Z",
                        "createdBy": 1001,
                        "updatedBy": 1001
                      }
                    ],
                    "pageInfo": {
                      "mode": "offset",
                      "page": 1,
                      "pageSize": 20,
                      "totalItems": "1",
                      "totalPages": 1,
                      "hasMore": false
                    }
                  },
                  "traceId": "0195f2a0-7c44-7b2e-9f3a-2a6f5d8e91ab"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/settings/v1/backend-api/system-settings/{namespace}/{key}": {
      "get": {
        "tags": ["settings"],
        "operationId": "systemSettings.retrieve",
        "summary": "Retrieve a single system setting",
        "description": "Retrieve a single system setting identified by namespace and key.",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-api-surface": "backend-api",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "$ref": "#/components/parameters/NamespacePath" },
          { "$ref": "#/components/parameters/KeyPath" }
        ],
        "responses": {
          "200": {
            "description": "System setting retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemSettingResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "put": {
        "tags": ["settings"],
        "operationId": "systemSettings.update",
        "summary": "Update a system setting",
        "description": "Update a single system setting identified by namespace and key.",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-api-surface": "backend-api",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "$ref": "#/components/parameters/NamespacePath" },
          { "$ref": "#/components/parameters/KeyPath" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSystemSettingRequest"
              },
              "example": {
                "settingValue": { "enabled": true },
                "valueType": "object",
                "scope": "region",
                "scopeValue": "cn-east-1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "System setting updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemSettingResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/settings/v1/backend-api/revisions": {
      "get": {
        "tags": ["settings"],
        "operationId": "revisions.list",
        "summary": "List configuration revision history",
        "description": "List configuration change revision history for audit. Supports optional filtering by configType, namespace, and configId, plus offset pagination.",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-api-surface": "backend-api",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "configType",
            "in": "query",
            "required": false,
            "description": "Filter revisions by configuration type.",
            "schema": {
              "type": "string",
              "enum": ["user", "tenant", "system"]
            }
          },
          {
            "name": "namespace",
            "in": "query",
            "required": false,
            "description": "Filter revisions by namespace.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "configId",
            "in": "query",
            "required": false,
            "description": "Filter revisions by configuration resource id.",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "One-based page index for offset pagination. Default 1.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Page size for offset pagination. Default 20, maximum 200.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 200,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Configuration revision history retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigRevisionListResponse"
                },
                "example": {
                  "code": 0,
                  "data": {
                    "items": [
                      {
                        "id": 12884901888,
                        "tenantId": 1,
                        "configType": "tenant",
                        "configId": 12884901888,
                        "namespace": "feature-flags",
                        "configKey": "beta-ui",
                        "oldValue": { "enabled": true },
                        "newValue": { "enabled": false },
                        "operation": "update",
                        "operatorId": 1001,
                        "operatorIp": "10.0.0.1",
                        "createdAt": "2026-07-01T02:30:00.000Z"
                      }
                    ],
                    "pageInfo": {
                      "mode": "offset",
                      "page": 1,
                      "pageSize": 20,
                      "totalItems": "1",
                      "totalPages": 1,
                      "hasMore": false
                    }
                  },
                  "traceId": "0195f2a0-7c44-7b2e-9f3a-2a6f5d8e91ab"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Administrator bearer token issued by SDKWork IAM. Required for all backend-api operations."
      }
    },
    "parameters": {
      "NamespacePath": {
        "name": "namespace",
        "in": "path",
        "required": true,
        "description": "Configuration namespace.",
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "KeyPath": {
        "name": "key",
        "in": "path",
        "required": true,
        "description": "Configuration key.",
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Validation error. ProblemDetail.code is 40001.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetail" },
            "example": {
              "type": "about:blank",
              "title": "Bad Request",
              "status": 400,
              "code": 40001,
              "detail": "Validation error",
              "traceId": "0195f2a0-7c44-7b2e-9f3a-2a6f5d8e91ab"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required. ProblemDetail.code is 40101.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetail" },
            "example": {
              "type": "about:blank",
              "title": "Unauthorized",
              "status": 401,
              "code": 40101,
              "detail": "Authentication required",
              "traceId": "0195f2a0-7c44-7b2e-9f3a-2a6f5d8e91ab"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Permission denied. ProblemDetail.code is 40301.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetail" },
            "example": {
              "type": "about:blank",
              "title": "Forbidden",
              "status": 403,
              "code": 40301,
              "detail": "Permission required",
              "traceId": "0195f2a0-7c44-7b2e-9f3a-2a6f5d8e91ab"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found. ProblemDetail.code is 40401.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetail" },
            "example": {
              "type": "about:blank",
              "title": "Not Found",
              "status": 404,
              "code": 40401,
              "detail": "Resource not found",
              "traceId": "0195f2a0-7c44-7b2e-9f3a-2a6f5d8e91ab"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflicting state. ProblemDetail.code is 40901.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetail" },
            "example": {
              "type": "about:blank",
              "title": "Conflict",
              "status": 409,
              "code": 40901,
              "detail": "Conflict",
              "traceId": "0195f2a0-7c44-7b2e-9f3a-2a6f5d8e91ab"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error. ProblemDetail.code is 50001.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetail" },
            "example": {
              "type": "about:blank",
              "title": "Internal Server Error",
              "status": 500,
              "code": 50001,
              "detail": "Internal error",
              "traceId": "0195f2a0-7c44-7b2e-9f3a-2a6f5d8e91ab"
            }
          }
        }
      }
    },
    "schemas": {
      "ConfigValueType": {
        "type": "string",
        "enum": ["string", "number", "boolean", "object", "array", "i18n"],
        "description": "Discriminator for how the configuration value should be interpreted."
      },
      "ConfigScope": {
        "type": "string",
        "enum": ["global", "region"],
        "description": "Scope at which a system setting applies."
      },
      "ConfigType": {
        "type": "string",
        "enum": ["user", "tenant", "system"],
        "description": "Kind of configuration a revision refers to."
      },
      "ConfigOperation": {
        "type": "string",
        "enum": ["create", "update", "delete"],
        "description": "Operation captured by a configuration revision."
      },
      "TenantConfig": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "tenantId", "namespace", "configKey", "configValue", "valueType", "createdAt", "updatedAt", "createdBy", "updatedBy"],
        "description": "A single tenant configuration entry.",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique tenant configuration identifier."
          },
          "tenantId": {
            "type": "integer",
            "format": "int64",
            "description": "Owning tenant identifier."
          },
          "namespace": {
            "type": "string",
            "description": "Configuration namespace."
          },
          "configKey": {
            "type": "string",
            "description": "Configuration key within the namespace."
          },
          "configValue": {
            "type": "object",
            "additionalProperties": true,
            "description": "Configuration payload. Shape is governed by valueType."
          },
          "valueType": {
            "$ref": "#/components/schemas/ConfigValueType"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp (UTC)."
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp (UTC)."
          },
          "createdBy": {
            "type": "integer",
            "format": "int64",
            "description": "Identifier of the operator who created the configuration."
          },
          "updatedBy": {
            "type": "integer",
            "format": "int64",
            "description": "Identifier of the operator who last updated the configuration."
          }
        }
      },
      "UpdateTenantConfigRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["configValue", "valueType"],
        "description": "Request body for updating a single tenant configuration.",
        "properties": {
          "configValue": {
            "type": "object",
            "additionalProperties": true,
            "description": "New configuration payload."
          },
          "valueType": {
            "$ref": "#/components/schemas/ConfigValueType"
          }
        }
      },
      "SystemSetting": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "namespace", "settingKey", "settingValue", "valueType", "scope", "scopeValue", "createdAt", "updatedAt", "createdBy", "updatedBy"],
        "description": "A single system setting entry.",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique system setting identifier."
          },
          "namespace": {
            "type": "string",
            "description": "Setting namespace."
          },
          "settingKey": {
            "type": "string",
            "description": "Setting key within the namespace."
          },
          "settingValue": {
            "type": "object",
            "additionalProperties": true,
            "description": "Setting payload. Shape is governed by valueType."
          },
          "valueType": {
            "$ref": "#/components/schemas/ConfigValueType"
          },
          "scope": {
            "$ref": "#/components/schemas/ConfigScope"
          },
          "scopeValue": {
            "type": ["string", "null"],
            "description": "Scope qualifier, for example a region code when scope is 'region'. Null when scope is 'global'."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp (UTC)."
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp (UTC)."
          },
          "createdBy": {
            "type": "integer",
            "format": "int64",
            "description": "Identifier of the operator who created the setting."
          },
          "updatedBy": {
            "type": "integer",
            "format": "int64",
            "description": "Identifier of the operator who last updated the setting."
          }
        }
      },
      "UpdateSystemSettingRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["settingValue", "valueType", "scope"],
        "description": "Request body for updating a single system setting.",
        "properties": {
          "settingValue": {
            "type": "object",
            "additionalProperties": true,
            "description": "New setting payload."
          },
          "valueType": {
            "$ref": "#/components/schemas/ConfigValueType"
          },
          "scope": {
            "$ref": "#/components/schemas/ConfigScope"
          },
          "scopeValue": {
            "type": ["string", "null"],
            "description": "Scope qualifier. Must be null when scope is 'global'."
          }
        }
      },
      "ConfigRevision": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "tenantId", "configType", "configId", "namespace", "configKey", "oldValue", "newValue", "operation", "operatorId", "operatorIp", "createdAt"],
        "description": "A single configuration change revision record for audit.",
        "properties": {
          "id": {
            "type": "integer",
