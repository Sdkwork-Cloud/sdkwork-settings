{
  "name": "sdkwork-settings",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm dev:browser",
    "dev:browser": "pnpm dev:browser:postgres:standalone",
    "dev:browser:postgres": "pnpm dev:browser:postgres:standalone",
    "dev:browser:postgres:standalone": "pnpm --dir apps/sdkwork-settings-pc dev",
    "dev:browser:sqlite": "pnpm --dir apps/sdkwork-settings-pc dev",
    "dev:desktop": "pnpm dev:desktop:postgres:standalone",
    "dev:desktop:postgres": "pnpm dev:desktop:postgres:standalone",
    "dev:desktop:postgres:standalone": "pnpm --dir apps/sdkwork-settings-pc dev",
    "dev:desktop:sqlite": "pnpm --dir apps/sdkwork-settings-pc dev",
    "dev:server": "cargo run -p sdkwork-settings-standalone-gateway --bin sdkwork-settings-standalone-gateway",
    "gateway:run:standalone": "cargo run -p sdkwork-settings-standalone-gateway --bin sdkwork-settings-standalone-gateway",
    "gateway:build:standalone": "cargo build -p sdkwork-settings-standalone-gateway --bin sdkwork-settings-standalone-gateway",
    "gateway:validate:standalone": "cargo check -p sdkwork-settings-standalone-gateway",
    "gateway:package:standalone": "cargo build -p sdkwork-settings-standalone-gateway --release --bin sdkwork-settings-standalone-gateway",
    "gateway:package:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs bundle --root .",
    "gateway:validate:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs validate --root .",
    "gateway:assembly:materialize": "node ../sdkwork-specs/tools/materialize-gateway-assembly.mjs --root .",
    "gateway:assembly:validate": "node ../sdkwork-specs/tools/validate-gateway-assembly.mjs --root .",
    "gateway:route-composition:audit": "node ../sdkwork-specs/tools/check-route-path-collisions.mjs --root .",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "start": "pnpm --dir apps/sdkwork-settings-pc preview",
    "build": "pnpm --dir apps/sdkwork-settings-pc build",
    "build:desktop": "pnpm build",
    "test": "node --test tests/contract/database-framework.contract.test.mjs",
    "check": "pnpm check:pnpm-script-standard && pnpm check:agent-workflow-standard && pnpm check:app-composition && pnpm test:single-http-ingress && pnpm gateway:assembly:validate && pnpm gateway:route-composition:audit && pnpm test:api-response-envelope && pnpm db:validate && pnpm topology:validate",
    "verify": "pnpm check && pnpm test && pnpm typecheck && cargo test --workspace",
    "clean": "node -e \"require('fs').rmSync('apps/sdkwork-settings-pc/dist',{recursive:true,force:true}); require('fs').rmSync('.runtime/dev-sites',{recursive:true,force:true})\"",
    "typecheck": "pnpm --dir apps/sdkwork-settings-pc lint",
    "lint": "pnpm --dir apps/sdkwork-settings-pc lint",
    "format": "cargo fmt --all",
    "format:check": "cargo fmt --all -- --check",
    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --product-prefix settings,config",
    "check:agent-workflow-standard": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root .",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "check:unified-postgres-profile": "node ../sdkwork-specs/tools/check-unified-postgres-profile.mjs",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:postgres:plan": "pnpm db:plan",
    "db:postgres:init": "pnpm db:init",
    "db:postgres:migrate": "pnpm db:migrate",
    "release:build": "pnpm build",
    "release:package:check": "pnpm build",
    "release:validate": "pnpm check",
    "test:database-framework": "node --test tests/contract/database-framework.contract.test.mjs",
    "test:single-http-ingress": "node ../sdkwork-specs/tools/check-single-http-ingress.mjs --root .",
    "test:api-response-envelope": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --root .",
    "test:api-operation-patterns": "node ../sdkwork-specs/tools/check-api-operation-patterns.mjs --root .",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_settings_baseline.sql --module-id settings --owner settings-platform --prefixes stg_ --engines postgres,sqlite",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
