# SDKWork Settings PostgreSQL 开发环境配置
# 复制为 .env.postgres 并修改

# Unified SDKWork PostgreSQL profile (required by check:unified-postgres-profile).
SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_settings
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_settings
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_settings
SDKWORK_CLAW_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_CLAW_DATABASE_SSL_MODE=disable
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=10

# Required for database init when creating roles/databases with an admin connection.
SDKWORK_CLAW_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_ADMIN_PORT=5432
SDKWORK_CLAW_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_CLAW_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_CLAW_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_CLAW_DATABASE_ADMIN_SSL_MODE=disable

# Optional: direct connection URL. If set, it takes precedence over split fields above.
# SDKWORK_CLAW_DATABASE_URL=postgresql://sdkwork_settings:sdkworkdev123@127.0.0.1:5432/sdkwork_settings?sslmode=disable

SETTINGS_DATABASE_URL=postgres://sdkwork:sdkwork@localhost:5432/sdkwork_settings
SDKWORK_SETTINGS_APP_ROOT=.
SDKWORK_SETTINGS_API_BIND=0.0.0.0:8080
RUST_LOG=debug
SDKWORK_SETTINGS_DEPLOYMENT_PROFILE=standalone
