# SDKWork Settings 环境变量示例
# 复制为 .env 并根据环境修改

# === 数据库配置 ===
# PostgreSQL: postgres://user:pass@localhost:5432/sdkwork_settings
# SQLite: sqlite://data/settings.db?mode=rwc
SETTINGS_DATABASE_URL=postgres://sdkwork:sdkwork@localhost:5432/sdkwork_settings

# 应用根目录(用于定位 database/ 资产)
SDKWORK_SETTINGS_APP_ROOT=.

# === HTTP 服务配置 ===
SDKWORK_SETTINGS_API_BIND=0.0.0.0:8080
SDKWORK_SETTINGS_GATEWAY_BIND=0.0.0.0:8080

# === ID 生成配置 ===
SDKWORK_SETTINGS_ID_NODE_ID=0

# === 日志配置 ===
RUST_LOG=info
SDKWORK_SETTINGS_LOG_FORMAT=full

# === IAM 配置 ===
SDKWORK_IAM_JWT_ISSUER=https://iam.sdkwork.com
SDKWORK_IAM_JWT_AUDIENCE=sdkwork-settings
SDKWORK_IAM_JWKS_URL=https://iam.sdkwork.com/.well-known/jwks.json

# === Drive 配置 ===
SDKWORK_DRIVE_ENDPOINT=http://localhost:8090
SDKWORK_DRIVE_APP_ID=settings

# === 部署 profile ===
SDKWORK_SETTINGS_DEPLOYMENT_PROFILE=standalone

# === 运行时拓扑(Phase 1 静态) ===
SDKWORK_SETTINGS_SERVICE_NAME=sdkwork-settings-api-server
