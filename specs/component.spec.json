{
  "schemaVersion": 1,
  "component": {
    "identity": {
      "applicationCode": "settings",
      "domain": "system",
      "kind": "application",
      "displayName": "SDKWork Settings",
      "description": "SDKWork Settings configuration center providing multi-tenant, multi-user, multi-language configuration management with multi-architecture integration support.",
      "vendor": "SDKWork",
      "license": "AGPL-3.0-or-later"
    },
    "surfaces": [
      { "name": "app-api", "kind": "http", "authority": "apis/app-api/settings/sdkwork-settings-app-api.openapi.json" },
      { "name": "backend-api", "kind": "http", "authority": "apis/backend-api/settings/sdkwork-settings-backend-api.openapi.json" }
    ],
    "canonicalSpecs": [
      { "path": "../sdkwork-specs/SOUL.md", "purpose": "agent execution soul" },
